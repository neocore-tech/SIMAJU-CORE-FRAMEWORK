#!/usr/bin/env node
'use strict';

const fs = require('fs');
const path = require('path');

const args = process.argv.slice(2);
const command = args[0];

/**
 * Simaju CLI Tool (Bab 10 & 16)
 * ─────────────────────────────────────────────────────────────
 */

if (!command) {
  try {
    const fs = require('fs');
    const branding = fs.readFileSync(path.join(__dirname, 'name.txt'), 'utf8');
    console.log(`\x1b[36m${branding}\x1b[0m`);
    console.log(' \x1b[1m\x1b[35mSIMAJU CORE FRAMEWORK\x1b[0m\n');
  } catch (e) {
    console.log('SIMAJU CORE FRAMEWORK');
  }

  console.log(`
  Commands:
    make:module <name>     Create a new modular feature with premium base code
    make:migration <name>  Create a new migration file
    db:migrate [conn]      Run pending migrations
    db:rollback [conn]     Rollback last migration batch
    db:ping [conn]         Check database connection
    install:all            Install all modules, plugins, and themes from simaju.json
    module:install <url>   Install a module from Git
    plugin:install <url>   Install a plugin from Git
    plugin:list            List all installed plugins
    plugin:migrate <name>  Run migrations for a specific plugin
    theme:list             List all installed themes
    theme:install <url>    Install a theme from Git
    theme:activate <name>  Activate a specific theme
    init                   Run interactive setup wizard
    help                   Show this help
  `);
  process.exit(0);
}

const commands = {
  'theme:list': () => {
    const ThemeManager = require('./src/core/theme-manager');
    const themes = ThemeManager.getInstalledThemes();
    const active = ThemeManager.getActiveTheme();
    
    if (themes.length === 0) {
      console.log('No themes installed.');
      return;
    }

    console.log('\n\x1b[1m\x1b[36mInstalled Themes:\x1b[0m');
    themes.forEach(t => {
      const isActive = t.id === active;
      console.log(`${isActive ? '\x1b[32m●\x1b[0m' : '○'} ${t.name} (v${t.version || '1.0.0'})${isActive ? ' \x1b[32m[Active]\x1b[0m' : ''}`);
    });
    console.log('');
  },

  'theme:install': (url) => {
    if (!url) return console.error('Error: Theme Git URL is required');
    const { spawnSync } = require('child_process');
    const themeName = path.basename(url, '.git');
    const targetPath = path.join(__dirname, 'src', 'themes', themeName);

    if (fs.existsSync(targetPath)) {
      return console.error(`Error: Theme [${themeName}] already exists`);
    }

    console.log(`🚀 Installing theme [${themeName}]...`);
    const result = spawnSync('git', ['clone', url, targetPath], { stdio: 'inherit' });

    if (result.status === 0) {
      console.log(`✅ Theme [${themeName}] installed successfully.`);
    } else {
      console.error(`❌ Failed to install theme [${themeName}].`);
    }
  },

  'theme:activate': (name) => {
    if (!name) return console.error('Error: Theme name is required');
    const ThemeManager = require('./src/core/theme-manager');
    try {
      ThemeManager.activate(name);
      console.log(`\x1b[32m✅ Theme [${name}] activated successfully.\x1b[0m`);
      console.log(`👉 Restart server to apply changes.`);
    } catch (err) {
      console.error(`❌ Activation failed: ${err.message}`);
    }
  },
  'make:module': (name) => {
    if (!name) return console.error('Error: Module name is required');
    const modulePath = path.join(__dirname, 'src', 'modules', name);
    
    if (fs.existsSync(modulePath)) {
      return console.error(`Error: Module [${name}] already exists`);
    }

    fs.mkdirSync(modulePath, { recursive: true });
    
    const camelName = name.charAt(0).toUpperCase() + name.slice(1);
    
    const templates = [
      { 
        name: `${name}.controller.js`, 
        content: `'use strict';

const ${camelName}Service = require('./${name}.service');
const Response = require('../../utils/response');

class ${camelName}Controller {
  static async index(req, res) {
    try {
      const data = await ${camelName}Service.getAll();
      return Response.success(res, data, 'Data fetched successfully');
    } catch (error) {
      return Response.error(res, error.message);
    }
  }

  static async store(req, res) {
    try {
      const data = await ${camelName}Service.create(req.body);
      return Response.success(res, data, 'Data created successfully', 201);
    } catch (error) {
      return Response.error(res, error.message);
    }
  }
}

module.exports = ${camelName}Controller;`
      },
      { 
        name: `${name}.service.js`,    
        content: `'use strict';

const DB = require('../../database');

class ${camelName}Service {
  static async getAll() {
    // Example: return await DB.table('${name}s').select('*');
    return []; 
  }

  static async create(data) {
    // Example: return await DB.table('${name}s').insert(data);
    return data;
  }
}

module.exports = ${camelName}Service;`
      },
      { 
        name: `${name}.route.js`,      
        content: `'use strict';

const express = require('express');
const router = express.Router();
const ${camelName}Controller = require('./${name}.controller');

router.get('/', ${camelName}Controller.index);
router.post('/', ${camelName}Controller.store);

module.exports = router;`
      },
      { 
        name: `${name}.validation.js`, 
        content: `'use strict';

/**
 * Validation rules for ${camelName}
 */
module.exports = {
  create: {
    // Define rules here
  }
};`
      },
    ];

    templates.forEach(t => {
      fs.writeFileSync(path.join(modulePath, t.name), t.content);
    });

    console.log(`\n\x1b[32m✅ Module [${name}] created successfully at src/modules/${name}\x1b[0m`);
    console.log(`\x1b[33m👉 Next step: Register it in src/core/router.js:\x1b[0m`);
    console.log(`   router.use('/${name}', require('../modules/${name}/${name}.route'));\n`);
  },

  'make:migration': (name) => {
    if (!name) return console.error('Error: Migration name is required');
    const Migration = require('./src/database/migration-manager');
    const filename = Migration.create(name);
    console.log(`✅ Migration created: src/database/migrations/${filename}`);
  },

  'db:migrate': async (conn) => {
    const DB = require('./src/database');
    const config = require('./src/config/database');
    const Migration = require('./src/database/migration-manager');
    
    try {
      if (conn) config.default = conn;
      await DB.boot(config);
      await Migration.migrate();
      await DB.disconnect();
    } catch (err) {
      console.error('❌ Migration failed:', err.message);
      process.exit(1);
    }
  },

  'db:seed': async (name) => {
    const DB = require('./src/database');
    const config = require('./src/config/database');
    const SeederManager = require('./src/database/seeder-manager');

    try {
      await DB.boot(config);
      await SeederManager.run(name || null);
    } catch (err) {
      console.error('❌ Seeder failed:', err.message);
      process.exit(1);
    }
  },

  'db:rollback': async (conn) => {
    const DB = require('./src/database');
    const config = require('./src/config/database');
    const Migration = require('./src/database/migration-manager');
    
    try {
      if (conn) config.default = conn;
      await DB.boot(config);
      await Migration.rollback();
      await DB.disconnect();
    } catch (err) {
      console.error('❌ Rollback failed:', err.message);
      process.exit(1);
    }
  },

  'db:ping': async (conn) => {
    const DB = require('./src/database');
    const config = require('./src/config/database');
    try {
      if (conn) config.default = conn;
      await DB.boot(config);
      const status = await DB.ping();
      console.log('📡 Database Status:', status);
      await DB.disconnect();
    } catch (err) {
      console.error('❌ Database connection failed:', err.message);
    }
  },
  
  'plugin:install': (url) => {
    if (!url) return console.error('Error: Plugin Git URL is required');
    const { spawnSync } = require('child_process');
    const pluginName = path.basename(url, '.git');
    const targetPath = path.join(__dirname, 'src', 'plugins', pluginName);

    console.log(`🚀 Installing plugin [${pluginName}]...`);
    const result = spawnSync('git', ['clone', url, targetPath], { stdio: 'inherit' });

    if (result.status === 0) {
      console.log(`✅ Plugin [${pluginName}] installed successfully.`);
    } else {
      console.error(`❌ Failed to install plugin [${pluginName}].`);
    }
  },

  'plugin:list': () => {
    const PluginManager = require('./src/core/plugin-manager');
    const plugins = PluginManager.getInstalledPlugins();
    
    if (plugins.length === 0) {
      console.log('No plugins installed.');
      return;
    }

    console.log('\x1b[1m\x1b[32mInstalled Plugins:\x1b[0m');
    plugins.forEach(p => {
      console.log(`- ${p.name} (v${p.version})`);
    });
  },

  'plugin:migrate': async (name) => {
    if (!name) return console.error('Error: Plugin name is required');
    const pluginPath = path.join(__dirname, 'src', 'plugins', name);
    const migrationPath = path.join(pluginPath, 'migrations');

    if (!fs.existsSync(migrationPath)) {
      return console.error(`Error: Plugin [${name}] does not have a migrations folder`);
    }

    const DB = require('./src/database');
    const config = require('./src/config/database');
    const Migration = require('./src/database/migration-manager');
    
    try {
      console.log(`🗄️ Running migrations for plugin [${name}]...`);
      await DB.boot(config);
      // We temporarily change the migration directory
      const originalPath = Migration.migrationsPath;
      Migration.migrationsPath = migrationPath;
      
      await Migration.migrate();
      
      Migration.migrationsPath = originalPath;
      await DB.disconnect();
      console.log(`✅ Plugin [${name}] migrations completed.`);
    } catch (err) {
      console.error(`❌ Plugin [${name}] migration failed:`, err.message);
      process.exit(1);
    }
  },
  'module:install': (nameOrUrl, explicitName) => {
    if (!nameOrUrl) return console.error('Error: Module name or URL is required');
    const { spawnSync } = require('child_process');
    const os = require('os');
    
    let url = nameOrUrl;
    let moduleName = explicitName || path.basename(url, '.git');
    let isSparse = false;
    
    // Jika input hanya nama modul (tanpa / atau ://), ambil URL dari registry
    if (!nameOrUrl.includes('/') && !nameOrUrl.includes('\\\\')) {
       const configPath = path.join(__dirname, 'simaju.json');
       if (fs.existsSync(configPath)) {
         const config = JSON.parse(fs.readFileSync(configPath, 'utf8'));
         url = config.registry && config.registry.modules;
       }
       if (!url) return console.error(`❌ Error: Cannot install [${nameOrUrl}], no modules registry found in simaju.json`);
       moduleName = nameOrUrl;
       isSparse = true;
    }

    const targetPath = path.join(__dirname, 'src', 'modules', moduleName);

    if (fs.existsSync(targetPath)) {
      return console.error(`⚠️ Error: Module [${moduleName}] already exists in src/modules/`);
    }

    console.log(`🚀 Installing module [${moduleName}]...`);
    
    if (isSparse) {
      // ── SPARSE CHECKOUT LOGIC ──
      const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'simaju-module-'));
      try {
        console.log(`   Connecting to registry...`);
        let res = spawnSync('git', ['clone', '--filter=blob:none', '--no-checkout', url, tempDir], { stdio: 'inherit' });
        if (res.status !== 0) throw new Error('Git clone failed');
        
        console.log(`   Fetching specific module [${moduleName}]...`);
        res = spawnSync('git', ['sparse-checkout', 'set', moduleName], { cwd: tempDir, stdio: 'inherit' });
        if (res.status !== 0) throw new Error('Git sparse-checkout set failed');
        
        res = spawnSync('git', ['checkout'], { cwd: tempDir, stdio: 'inherit' });
        if (res.status !== 0) throw new Error('Git checkout failed');
        
        const sourceModulePath = path.join(tempDir, moduleName);
        if (!fs.existsSync(sourceModulePath)) {
           throw new Error(`Module [${moduleName}] not found in registry repository`);
        }
        
        fs.cpSync(sourceModulePath, targetPath, { recursive: true });
        console.log(`\\x1b[32m✅ Module [${moduleName}] installed successfully via Sparse-Checkout.\\x1b[0m`);
      } catch (err) {
        console.error(`❌ Failed to install module [${moduleName}]: ${err.message}`);
      } finally {
        if (fs.existsSync(tempDir)) fs.rmSync(tempDir, { recursive: true, force: true });
      }
    } else {
      // ── NORMAL CLONE LOGIC ──
      const result = spawnSync('git', ['clone', url, targetPath], { stdio: 'inherit' });
      if (result.status === 0) {
        const gitPath = path.join(targetPath, '.git');
        if (fs.existsSync(gitPath)) {
          fs.rmSync(gitPath, { recursive: true, force: true });
        }
        console.log(`\\x1b[32m✅ Module [${moduleName}] installed successfully.\\x1b[0m`);
      } else {
        console.error(`❌ Failed to install module [${moduleName}].`);
      }
    }
  },

  'install:all': () => {
    const configPath = path.join(__dirname, 'simaju.json');
    if (!fs.existsSync(configPath)) {
      return console.error('❌ Error: simaju.json not found in root directory.');
    }

    let config;
    try {
      config = JSON.parse(fs.readFileSync(configPath, 'utf8'));
    } catch (e) {
      return console.error('❌ Error: simaju.json contains invalid JSON.');
    }

    console.log('\\n\\x1b[1m\\x1b[36m🚀 Simaju Bulk Installer\\x1b[0m');
    console.log('──────────────────────────────────────────────────\\n');

    // Modul bisa array (registry sparse checkout) atau object (url normal)
    if (config.modules && Array.isArray(config.modules)) {
      console.log(`\\n📦 Installing Modules from Registry...`);
      for (const mod of config.modules) {
        console.log(`\\n➤ [${mod}]`);
        commands['module:install'](mod);
      }
    } else if (config.modules) {
      console.log(`\\n📦 Installing Modules from URLs...`);
      for (const [name, url] of Object.entries(config.modules)) {
        console.log(`\\n➤ [${name}] from ${url}`);
        commands['module:install'](url, name);
      }
    }

    const installItems = (type, items, handler) => {
      if (!items || Object.keys(items).length === 0) return;
      console.log(`\\n📦 Installing ${type}...`);
      for (const [name, url] of Object.entries(items)) {
        console.log(`\\n➤ [${name}] from ${url}`);
        handler(url, name);
      }
    };

    installItems('Plugins', config.plugins, commands['plugin:install']);
    installItems('Themes', config.themes, commands['theme:install']);

    console.log('\\n\\x1b[1m\\x1b[32m✨ Bulk Installation Completed!\\x1b[0m\\n');
  },

  'init': async () => {
    const readline = require('readline');
    const rl = readline.createInterface({
      input: process.stdin,
      output: process.stdout
    });

    const question = (query) => new Promise((resolve) => rl.question(query, resolve));

    console.log('\n\x1b[1m\x1b[36m🚀 Welcome to Simaju Core Setup Wizard\x1b[0m');
    console.log('──────────────────────────────────────────────────\n');

    try {
      const appName = await question('🏷️  App Name (Default: Simaju Core): ') || 'Simaju Core';
      
      console.log('\n🗄️  Select Database Engine:');
      console.log('1. SQLite (Recommended for dev)');
      console.log('2. MySQL');
      console.log('3. PostgreSQL');
      const dbType = await question('Choice (1-3): ');

      let dbConfig = {
        type: dbType === '2' ? 'mysql' : (dbType === '3' ? 'postgres' : 'sqlite'),
        host: 'localhost',
        user: 'root',
        pass: '',
        name: 'simaju_db'
      };

      if (dbType !== '1') {
        dbConfig.host = await question('   Host (Default: localhost): ') || 'localhost';
        dbConfig.user = await question('   Username: ');
        dbConfig.pass = await question('   Password: ');
        dbConfig.name = await question('   Database Name: ');
      }

      console.log('\n🧩  Enable Core Modules?');
      const enableAuth = (await question('   Enable Authentication System? (y/n): ')).toLowerCase() === 'y';
      const enableCRM = (await question('   Enable Sample CRM Module? (y/n): ')).toLowerCase() === 'y';

      console.log('\n⚙️  Generating configuration...');

      // Generate .env
      const envContent = `APP_NAME="${appName}"
APP_ENV=development
APP_PORT=3000
APP_KEY=${Math.random().toString(36).substring(2, 15)}

DB_CONNECTION=${dbConfig.type}
DB_HOST=${dbConfig.host}
DB_PORT=${dbConfig.type === 'mysql' ? 3306 : 5432}
DB_DATABASE=${dbConfig.name}
DB_USERNAME=${dbConfig.user}
DB_PASSWORD=${dbConfig.pass}
`;

      fs.writeFileSync(path.join(__dirname, '.env'), envContent);
      console.log('✅ .env file created.');

      if (enableAuth) {
        console.log('📦 Activating Auth System...');
        // logic to enable auth could be copying files or updating router
      }

      console.log('\n\x1b[1m\x1b[32m✨ Setup Completed Successfully!\x1b[0m');
      console.log('👉 Next: Run \x1b[1m./simaju db:migrate\x1b[0m to initialize database.');
      console.log('👉 Then: Run \x1b[1mnpm run dev\x1b[0m to start the server.\n');

    } catch (err) {
      console.error('\n❌ Setup aborted:', err.message);
    } finally {
      rl.close();
    }
  }
};

if (commands[command]) {
  (async () => {
    await commands[command](args[1], args[2]);
  })();
} else {
  console.log(`Unknown command: ${command}`);
}
