<section class="welcome-section" style="background: linear-gradient(135deg, #1e1e1e 0%, #121212 100%); padding: 3rem; border-radius: 1rem; border: 1px solid #333; margin-bottom: 3rem;">
    <h1 style="color: #60a5fa; font-size: 4rem;">Neo Dark: Welcome, <span id="welcomeName">Pengguna</span>!</h1>
    <p style="color: #94a3b8; font-size: 1.2rem;">This is a custom theme override for Simaju Core.</p>
</section>

<div class="stats-grid">
    <div class="stat-card" style="background: #111; border-color: #60a5fa;">
        <div class="stat-label" style="color: #60a5fa;">Total Items</div>
        <div id="totalItems" class="stat-value">0</div>
    </div>
    <div class="stat-card" style="background: #111;">
        <div class="stat-label">Items Out</div>
        <div id="itemsOut" class="stat-value">0</div>
    </div>
    <div class="stat-card" style="background: #111;">
        <div class="stat-label">System Health</div>
        <div class="stat-value" style="color: #10b981;">Premium</div>
    </div>
</div>

<script>
    // Copy the logic from core dashboard but with maybe some extra theme-specific JS
    // For now, just reuse the logic
    const userJson = localStorage.getItem('user');
    const token = localStorage.getItem('token');
    
    if (!userJson || !token) {
        window.location.href = '/login';
    } else {
        const user = JSON.parse(userJson);
        document.querySelectorAll('#userName, #sideUserName').forEach(el => el.textContent = user.name);
        document.querySelectorAll('#userRole, #sideUserRole').forEach(el => el.textContent = user.role || 'user');
        if (document.getElementById('welcomeName')) document.getElementById('welcomeName').textContent = user.name.split(' ')[0];
    }

    async function fetchInventory() {
        try {
            const response = await fetch('/api/inventory', {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            const result = await response.json();
            if (response.ok) {
                document.getElementById('totalItems').textContent = result.data.items.length;
            }
        } catch (err) { console.error(err); }
    }
    fetchInventory();
</script>
