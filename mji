#!/usr/bin/env node
'use strict';

const { spawn } = require('child_process');
const path = require('path');

const args    = process.argv.slice(2);
const command = args[0];

// ── Help / Banner ──────────────────────────────────────────────
if (!command || command === 'help') {
  try {
    const fs = require('fs');
    const branding = fs.readFileSync(path.join(__dirname, 'name.txt'), 'utf8');
    console.log(`\x1b[36m${branding}\x1b[0m`);
    console.log(' \x1b[1m\x1b[35mSIMAJU CORE FRAMEWORK\x1b[0m\n');
  } catch (e) {
    console.log('SIMAJU CORE FRAMEWORK');
  }

  console.log(`
  \x1b[1mUsage:\x1b[0m  mji <command> [options]

  \x1b[33m🚀 Main Commands (Sangat Mudah):\x1b[0m
    up                   Jalankan Framework + Firewall bersamaan (Rekomendasi!)
    dev                  Jalankan Framework saja (Mode Development)
    guard                Jalankan Firewall saja (SIMAJU Guard - Rust)
    monit                Buka Dashboard Terminal (CPU, RAM, Network)

  \x1b[33m🛠️  Utility Commands:\x1b[0m
    migrate              Jalankan semua database migration
    rollback             Kembalikan (rollback) migration terakhir
    seed                 Isi database dengan data awal
    test                 Jalankan testing (Unit & API)
    install              Install dependency packages (via npm)

  \x1b[33mScaffolding:\x1b[0m
    make:module <name>   Create a new module
    make:migration <name> Create a new migration file

  \x1b[33mDatabase:\x1b[0m
    db:migrate [conn]    Run pending migrations
    db:rollback [conn]   Rollback last migration batch
    db:seed [seeder]     Run database seeders
    db:ping [conn]       Check database connection

  \x1b[33mPlugin & Theme:\x1b[0m
    plugin:list          List installed plugins
    theme:list           List installed themes
    theme:use <name>     Switch active theme

  \x1b[33mPackage Management:\x1b[0m
    install:all          Install all modules/plugins/themes from simaju.json
  `);
  process.exit(0);
}

// ── Core Commands (Sederhana tanpa 'run') ───────────────────────
const simajuPath = path.join(__dirname, 'simaju');

const scripts = {
  up() {
    console.log('\x1b[32m🚀 Starting SIMAJU Framework + Firewall...\x1b[0m');
    const child = spawn('npm', ['run', 'start'], { stdio: 'inherit', cwd: __dirname });
    child.on('exit', code => process.exit(code));
  },
  dev() {
    console.log('\x1b[32m🚀 Starting SIMAJU Core (Framework Only)...\x1b[0m');
    spawn('node', [path.join(__dirname, 'index.js')], {
      stdio: 'inherit',
      cwd: __dirname,
      env: { ...process.env, NODE_ENV: 'development' },
    });
  },
  guard() {
    console.log('\x1b[32m🛡️  Starting SIMAJU Guard (Firewall Only)...\x1b[0m');
    const child = spawn('npm', ['run', 'guard'], { stdio: 'inherit', cwd: __dirname });
    child.on('exit', code => process.exit(code));
  },
  migrate() {
    spawn('node', [simajuPath, 'db:migrate', ...args.slice(1)], { stdio: 'inherit' });
  },
  rollback() {
    spawn('node', [simajuPath, 'db:rollback', ...args.slice(1)], { stdio: 'inherit' });
  },
  seed() {
    spawn('node', [simajuPath, 'db:seed', ...args.slice(1)], { stdio: 'inherit' });
  },
  test() {
    console.log('\x1b[32m🧪 Running test suite...\x1b[0m');
    spawn('node', ['--test', 'tests/**/*.test.js'], { stdio: 'inherit', cwd: __dirname });
  },
};

if (scripts[command]) {
  scripts[command]();
} else if (command === 'run' && scripts[args[1]]) {
  // Dukung format lama: mji run dev -> mji dev
  scripts[args[1]]();
} else if (command === 'run') {
  console.error(`\x1b[31m❌ Unknown script: "${args[1]}"\x1b[0m`);
  process.exit(1);

// ── install — pengganti npm install ───────────────────────────
} else if (command === 'install' || command === 'i') {
  console.log('\x1b[32m📦 Installing dependencies...\x1b[0m');
  const child = spawn('npm', ['install', ...args.slice(1)], { stdio: 'inherit' });
  child.on('exit', code => process.exit(code));

// ── monit — custom process manager ────────────────────────────
} else if (command === 'monit') {
  console.log('\x1b[32m📈 Booting Simaju Process Manager...\x1b[0m');
  const child = spawn('node', [path.join(__dirname, 'scripts/monitor.js')], { stdio: 'inherit' });
  child.on('exit', code => process.exit(code));

// ── Delegate ke simaju CLI ────────────────────────────────────
} else {
  const simajuPath = path.join(__dirname, 'simaju');
  const child = spawn('node', [simajuPath, ...args], { stdio: 'inherit' });
  child.on('exit', code => process.exit(code));
}
