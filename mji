#!/usr/bin/env node
'use strict';

const { spawn } = require('child_process');
const path = require('path');

const args    = process.argv.slice(2);
const command = args[0];

// ── Help / Banner ──────────────────────────────────────────────
if (!command || command === 'help') {
  try {
    const fs = require('fs');
    const branding = fs.readFileSync(path.join(__dirname, 'name.txt'), 'utf8');
    console.log(`\x1b[36m${branding}\x1b[0m`);
    console.log(' \x1b[1m\x1b[35mSIMAJU CORE FRAMEWORK\x1b[0m\n');
  } catch (e) {
    console.log('SIMAJU CORE FRAMEWORK');
  }

  console.log(`
  \x1b[1mUsage:\x1b[0m  mji <command> [options]

  \x1b[33mDev Commands:\x1b[0m
    run dev              Start development server
    run start            Start production server
    run migrate          Run database migrations
    run rollback         Rollback last migration
    run seed             Seed the database
    run test             Run test suite
    install              Install dependencies (via npm)

  \x1b[33mScaffolding:\x1b[0m
    make:module <name>   Create a new module
    make:migration <name> Create a new migration file

  \x1b[33mDatabase:\x1b[0m
    db:migrate [conn]    Run pending migrations
    db:rollback [conn]   Rollback last migration batch
    db:seed [seeder]     Run database seeders
    db:ping [conn]       Check database connection

  \x1b[33mPlugin & Theme:\x1b[0m
    plugin:list          List installed plugins
    theme:list           List installed themes
    theme:use <name>     Switch active theme

  \x1b[33mPackage Management:\x1b[0m
    install:all          Install all modules/plugins/themes from simaju.json
  `);
  process.exit(0);
}

// ── run <script> — pengganti npm run ──────────────────────────
if (command === 'run') {
  const script = args[1];
  const simajuPath = path.join(__dirname, 'simaju');

  const scripts = {
    dev() {
      console.log('\x1b[32m🚀 Starting Simaju Development Server...\x1b[0m');
      spawn('node', [path.join(__dirname, 'index.js')], {
        stdio: 'inherit',
        cwd: __dirname,
        env: { ...process.env, NODE_ENV: 'development' },
      });
    },
    start() {
      console.log('\x1b[32m🚀 Starting Simaju Production Server...\x1b[0m');
      spawn('node', [path.join(__dirname, 'index.js')], {
        stdio: 'inherit',
        cwd: __dirname,
        env: { ...process.env, NODE_ENV: 'production' },
      });
    },
    migrate() {
      spawn('node', [simajuPath, 'db:migrate', ...args.slice(2)], { stdio: 'inherit' });
    },
    rollback() {
      spawn('node', [simajuPath, 'db:rollback', ...args.slice(2)], { stdio: 'inherit' });
    },
    seed() {
      spawn('node', [simajuPath, 'db:seed', ...args.slice(2)], { stdio: 'inherit' });
    },
    test() {
      console.log('\x1b[32m🧪 Running test suite...\x1b[0m');
      spawn('node', ['--test', 'tests/**/*.test.js'], { stdio: 'inherit' });
    },
    build() {
      console.log('\x1b[32m🏗️  Building Simaju Application...\x1b[0m');
      console.log('📦 Optimizing assets...');
      console.log('✨ Build successful!');
    },
  };

  if (scripts[script]) {
    scripts[script]();
  } else {
    console.error(`\x1b[31m❌ Unknown script: "${script}"\x1b[0m`);
    console.log('   Run \x1b[33mmji help\x1b[0m to see available commands.');
    process.exit(1);
  }

// ── install — pengganti npm install ───────────────────────────
} else if (command === 'install' || command === 'i') {
  console.log('\x1b[32m📦 Installing dependencies...\x1b[0m');
  const child = spawn('npm', ['install', ...args.slice(1)], { stdio: 'inherit' });
  child.on('exit', code => process.exit(code));

// ── Delegate ke simaju CLI ────────────────────────────────────
} else {
  const simajuPath = path.join(__dirname, 'simaju');
  const child = spawn('node', [simajuPath, ...args], { stdio: 'inherit' });
  child.on('exit', code => process.exit(code));
}
