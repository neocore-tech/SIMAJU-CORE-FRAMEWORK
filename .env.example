# ─────────────────────────────────────────────────────────────
# App Configuration
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
SLOW_QUERY_MS=1000
JWT_SECRET=secret_simaju_key_123
SIMAJU_ADMIN_KEY=ganti_dengan_key_aman_anda

# ─────────────────────────────────────────────────────────────
# Database Connection
# Pilih salah satu: mysql | postgres | sqlite | mongodb (RECOMMENDED: postgres)
# ─────────────────────────────────────────────────────────────
DB_CONNECTION=postgres

# ── MySQL ─────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=simaju
DB_USER=root
DB_PASS=
DB_POOL_MAX=10

# ── PostgreSQL ────────────────────────────────────────────────
PG_HOST=127.0.0.1
PG_PORT=5432
PG_NAME=simaju
PG_USER=postgres
PG_PASS=
PG_SSL=false
PG_POOL_MAX=10

# ── SQLite ────────────────────────────────────────────────────
SQLITE_PATH=./database.sqlite

# ── MongoDB ───────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
MONGO_DB=simaju
